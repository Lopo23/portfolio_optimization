def eur(x: float) -> str:
    return f"EUR {x:,.0f}"


def pct(x: float) -> str:
    return f"{x:.2%}"


def get_corr(a: str, b: str) -> float:
    if (a, b) in CORRELATIONS:
        return CORRELATIONS[(a, b)]
    if (b, a) in CORRELATIONS:
        return CORRELATIONS[(b, a)]
    if a == b:
        return 1.0
    raise KeyError(f"Missing correlation pair: ({a}, {b})")


def total_value(values: Dict[str, float]) -> float:
    return sum(values.values())


def normalize_weights(values: Dict[str, float]) -> Dict[str, float]:
    tv = total_value(values)
    if tv == 0:
        return {k: 0.0 for k in values}
    return {k: v / tv for k, v in values.items()}


def aggregate_current_by_sleeve(
    holdings: Dict[str, float],
    mapping: Dict[str, str],
) -> Dict[str, float]:
    out: Dict[str, float] = {}
    for security, value in holdings.items():
        sleeve = mapping[security]
        out[sleeve] = out.get(sleeve, 0.0) + value
    return out


def full_current_sleeve_weights() -> Dict[str, float]:
    sleeve_values = aggregate_current_by_sleeve(CURRENT_HOLDINGS_EUR, CURRENT_SECURITY_TO_SLEEVE)
    weights = normalize_weights(sleeve_values)
    return {sleeve: weights.get(sleeve, 0.0) for sleeve in THESIS_POLICY}


def target_weights() -> Dict[str, float]:
    return {k: v.target for k, v in THESIS_POLICY.items()}


def range_check(weights: Dict[str, float]) -> Dict[str, str]:
    out = {}
    for sleeve, policy in THESIS_POLICY.items():
        w = weights.get(sleeve, 0.0)
        if w < policy.min_w:
            out[sleeve] = f"Below minimum by {pct(policy.min_w - w)}"
        elif w > policy.max_w:
            out[sleeve] = f"Above maximum by {pct(w - policy.max_w)}"
        else:
            out[sleeve] = "Within range"
    return out


def rebalance_amounts(
    portfolio_value: float,
    current_weights: Dict[str, float],
    target_w: Dict[str, float],
) -> Dict[str, float]:
    out = {}
    for sleeve, tgt in target_w.items():
        cur = current_weights.get(sleeve, 0.0)
        out[sleeve] = (tgt - cur) * portfolio_value
    return out


# =============================================================================
# 7. PERFORMANCE METRICS
# =============================================================================

def portfolio_expected_return(weights: Dict[str, float], assumptions: Dict[str, Dict[str, float]]) -> float:
    return sum(weights.get(sleeve, 0.0) * assumptions[sleeve]["mu"] for sleeve in assumptions)


def portfolio_volatility(weights: Dict[str, float], assumptions: Dict[str, Dict[str, float]]) -> float:
    sleeves = list(assumptions.keys())
    var = 0.0
    for i in sleeves:
        for j in sleeves:
            wi = weights.get(i, 0.0)
            wj = weights.get(j, 0.0)
            si = assumptions[i]["sigma"]
            sj = assumptions[j]["sigma"]
            c = get_corr(i, j)
            var += wi * wj * si * sj * c
    return math.sqrt(max(var, 0.0))


def portfolio_beta(
    portfolio_weights: Dict[str, float],
    asset_betas: Dict[str, float],
) -> float:
    return sum(portfolio_weights.get(asset, 0.0) * asset_betas.get(asset, 0.0) for asset in portfolio_weights)


def sharpe_ratio_from_inputs(
    portfolio_return: float,
    risk_free_rate: float,
    portfolio_volatility_value: float,
) -> float:
    if portfolio_volatility_value == 0:
        return float("nan")
    return (portfolio_return - risk_free_rate) / portfolio_volatility_value


def treynor_ratio(
    portfolio_return: float,
    risk_free_rate: float,
    portfolio_beta_value: float,
) -> float:
    if portfolio_beta_value == 0:
        return float("nan")
    return (portfolio_return - risk_free_rate) / portfolio_beta_value


def jensens_alpha(
    portfolio_return: float,
    risk_free_rate: float,
    market_return: float,
    portfolio_beta_value: float,
) -> float:
    expected_capm_return = risk_free_rate + portfolio_beta_value * (market_return - risk_free_rate)
    return portfolio_return - expected_capm_return


def scenario_return(weights: Dict[str, float], scenario_shocks: Dict[str, float]) -> float:
    return sum(weights.get(sleeve, 0.0) * shock for sleeve, shock in scenario_shocks.items())


# =============================================================================
# 8. MONTE CARLO
# =============================================================================

def random_normal(mu: float, sigma: float) -> float:
    u1 = max(random.random(), 1e-12)
    u2 = random.random()
    z = math.sqrt(-2.0 * math.log(u1)) * math.cos(2.0 * math.pi * u2)
    return mu + sigma * z


def monte_carlo_projection(
    start_value: float,
    weights: Dict[str, float],
    assumptions: Dict[str, Dict[str, float]],
    years: int = 5,
    n_sims: int = 5000,
    annual_withdrawal_rate: float = 0.0,
) -> Dict[str, float]:
    endings = []
    drawdowns = []

    for _ in range(n_sims):
        v = start_value
        peak = start_value
        max_dd = 0.0

        for _ in range(years):
            annual_return = 0.0
            for sleeve, w in weights.items():
                if w == 0:
                    continue
                mu = assumptions[sleeve]["mu"]
                sigma = assumptions[sleeve]["sigma"]
                r = random_normal(mu, sigma)
                annual_return += w * r

            v *= (1.0 + annual_return)
            v *= (1.0 - annual_withdrawal_rate)

            if v > peak:
                peak = v
            dd = (peak - v) / peak if peak > 0 else 0.0
            if dd > max_dd:
                max_dd = dd

        endings.append(v)
        drawdowns.append(max_dd)

    endings.sort()
    drawdowns.sort()

    return {
        "mean": statistics.mean(endings),
        "median": statistics.median(endings),
        "p10": endings[int(0.10 * len(endings))],
        "p90": endings[int(0.90 * len(endings))],
        "loss_probability": sum(x < start_value for x in endings) / len(endings),
        "mean_max_drawdown": statistics.mean(drawdowns),
        "p90_max_drawdown": drawdowns[int(0.90 * len(drawdowns))],
    }


