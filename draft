def thesis_kpi_check(weights: Dict[str, float], assumptions: Dict[str, Dict[str, float]]) -> Dict[str, str]:
    out: Dict[str, str] = {}

    exp_return = portfolio_expected_return(weights, assumptions)
    vol = portfolio_volatility(weights, assumptions)
    beta_p = portfolio_beta(weights, ASSET_BETAS)

    sr = sharpe_ratio_from_inputs(
        portfolio_return=exp_return,
        risk_free_rate=RISK_FREE_RATE,
        portfolio_volatility_value=vol,
    )

    tr = treynor_ratio(
        portfolio_return=exp_return,
        risk_free_rate=RISK_FREE_RATE,
        portfolio_beta_value=beta_p,
    )

    alpha = jensens_alpha(
        portfolio_return=exp_return,
        risk_free_rate=RISK_FREE_RATE,
        market_return=POLICY_BENCHMARK_RETURN,
        portfolio_beta_value=beta_p,
    )

    liquidity = weights.get("Cash / Money Market", 0.0)
    five_day_liquidity_proxy = (
        weights.get("Cash / Money Market", 0.0)
        + weights.get("Government Bonds", 0.0)
        + weights.get("Inflation-Linked Bonds", 0.0)
    )

    crypto = weights.get("Crypto", 0.0)
    private_credit = weights.get("Private Credit", 0.0)

    out["Expected Return"] = f"{exp_return:.2%}"
    out["Volatility"] = f"{vol:.2%}"
    out["Portfolio Beta"] = f"{beta_p:.2f}"
    out["Sharpe Ratio"] = f"{sr:.2f}"
    out["Treynor Ratio"] = f"{tr:.4f}"
    out["Jensen Alpha"] = f"{alpha:.2%}"

    out["Sharpe KPI"] = "PASS" if sr > KPI_LIMITS["sharpe_min"] else f"FAIL ({sr:.2f} <= {KPI_LIMITS['sharpe_min']:.2f})"
    out["Treynor KPI"] = "PASS" if tr > 0 else f"FAIL ({tr:.4f} <= 0)"
    out["Jensen Alpha KPI"] = "PASS" if alpha >= 0 else f"FAIL ({alpha:.2%} < 0)"
    out["Volatility KPI"] = "PASS" if vol <= KPI_LIMITS["volatility_max"] else f"FAIL ({vol:.2%} > {KPI_LIMITS['volatility_max']:.2%})"
    out["Liquidity Floor KPI"] = "PASS" if liquidity >= KPI_LIMITS["liquidity_floor"] else f"FAIL ({liquidity:.2%} < {KPI_LIMITS['liquidity_floor']:.2%})"
    out["5-Day Liquidity KPI"] = "PASS" if five_day_liquidity_proxy >= KPI_LIMITS["five_day_liquidity_floor"] else f"FAIL ({five_day_liquidity_proxy:.2%} < {KPI_LIMITS['five_day_liquidity_floor']:.2%})"
    out["Crypto Cap KPI"] = "PASS" if crypto <= KPI_LIMITS["crypto_cap"] else f"FAIL ({crypto:.2%} > {KPI_LIMITS['crypto_cap']:.2%})"
    out["Private Credit Cap KPI"] = "PASS" if private_credit <= KPI_LIMITS["private_credit_cap"] else f"FAIL ({private_credit:.2%} > {KPI_LIMITS['private_credit_cap']:.2%})"

    range_status = range_check(weights)
    range_pass = all(status == "Within range" for status in range_status.values())
    out["Policy Range Compliance"] = "PASS" if range_pass else "FAIL"

    return out


