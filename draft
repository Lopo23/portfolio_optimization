def current_sector_exposure() -> Dict[str, float]:
    total = total_value(CURRENT_HOLDINGS_EUR)
    out: Dict[str, float] = {}
    for sec, value in CURRENT_HOLDINGS_EUR.items():
        s = CURRENT_SECURITY_META[sec]["sector"]
        out[s] = out.get(s, 0.0) + value / total
    return out


def concentration_flags() -> Dict[str, List[str]]:
    issuer_flags = []
    for sec, w in current_single_issuer_weights().items():
        if w > KPI_LIMITS["single_issuer_cap"]:
            issuer_flags.append(f"{sec}: {pct(w)} > issuer cap {pct(KPI_LIMITS['single_issuer_cap'])}")

    country_flags = []
    for country, w in current_country_exposure().items():
        if w > KPI_LIMITS["single_country_cap"]:
            country_flags.append(f"{country}: {pct(w)} > country cap {pct(KPI_LIMITS['single_country_cap'])}")

    sector_flags = []
    for sector, w in current_sector_exposure().items():
        if w > KPI_LIMITS["single_sector_cap"]:
            sector_flags.append(f"{sector}: {pct(w)} > sector cap {pct(KPI_LIMITS['single_sector_cap'])}")

    return {
        "issuer_flags": issuer_flags,
        "country_flags": country_flags,
        "sector_flags": sector_flags,
    }


