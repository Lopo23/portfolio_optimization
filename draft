    interest_coverage: Optional[float] = None
    forward_pe: Optional[float] = None
    shares_out_growth_5y: Optional[float] = None


def security_screen_comment(screen: EquityScreen) -> List[str]:
    comments: List[str] = []

    if screen.net_debt_to_ebitda is not None:
        if screen.net_debt_to_ebitda > 3.5:
            comments.append("Leverage looks elevated: permanent-loss risk needs scrutiny.")
        else:
            comments.append("Leverage appears manageable.")

    if screen.interest_coverage is not None:
        if screen.interest_coverage < 4:
            comments.append("Interest coverage is weak; refinancing / solvency risk may be material.")
        else:
            comments.append("Interest coverage looks acceptable.")

    if screen.operating_margin is not None:
        if screen.operating_margin > 0.18:
            comments.append("High operating margin may require a peak-cycle check.")
        else:
            comments.append("Operating margin does not immediately suggest an extreme peak-cycle level.")

    if screen.roic is not None:
        if screen.roic >= 0.12:
            comments.append("ROIC suggests decent business quality.")
        else:
            comments.append("ROIC is not particularly strong; quality should be validated carefully.")

    if screen.forward_pe is not None:
        if screen.forward_pe > 25:
            comments.append("Valuation looks demanding; upside may depend on optimistic assumptions.")
        else:
            comments.append("Valuation does not look obviously stretched on forward earnings alone.")

    if screen.fcf_yield is not None:
        if screen.fcf_yield < 0.03:
            comments.append("FCF yield looks thin; valuation support may be weak.")
        else:
            comments.append("FCF yield offers some valuation support.")

    return comments


